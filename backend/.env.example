# ==================== LLM & Embedding ====================
# 阿里云百炼 API Key（必填）
# 申请地址: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=your-dashscope-api-key
DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
OPENAI_MODEL=qwen3-max

# ==================== OpenRouter API ====================
# OpenRouter API Key（可选，用于多模型支持）
# 申请地址: https://openrouter.ai/
OPENROUTER_API_KEY=your-openrouter-api-key

# ==================== 文档解析 (DocMind) ====================
# 阿里云 DocMind 文档解析服务（可选）
# 申请地址: https://help.aliyun.com/zh/ram/user-guide/create-an-accesskey-pair
DOCMIND_ACCESS_KEY_ID=your-access-key-id
DOCMIND_ACCESS_KEY_SECRET=your-access-key-secret

# ==================== 搜索 API ====================
# 博查搜索 API（必填）
# 申请地址: https://open.bochaai.com/
BOCHA_API_KEY=your-bocha-api-key

# Serper 搜索 API（可选）
SERPER_API_KEY=your-serper-api-key

# ==================== 行业资讯 API ====================
# 聚合数据 - 股票行情 API（可选）
# 申请地址: https://www.juhe.cn/docs/api/id/21
JUHE_STOCK_API_KEY=your-juhe-stock-api-key

# ==================== 招投标 API ====================
# 阿里云市场 - 招投标信息 API（可选）
# 申请地址: https://market.aliyun.com/detail/cmapi00063550
BID_APP_KEY=your-bid-app-key
BID_APP_SECRET=your-bid-app-secret
BID_APP_CODE=your-bid-app-code

# ==================== Redis ====================
# AI Data Analyst 独立版 Docker 默认配置
REDIS_HOST=ai-data-analyst-redis
REDIS_PORT=6379
REDIS_PASSWORD=

# ==================== PostgreSQL ====================
# AI Data Analyst 独立版 Docker 默认配置，与 docker-compose.yml 保持一致
POSTGRES_HOST=ai-data-analyst-postgres
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres123
POSTGRES_DB=industry_assistant

# ==================== Milvus ====================
# AI Data Analyst 独立版 Docker 默认配置
MILVUS_HOST=ai-data-analyst-milvus
MILVUS_PORT=19530

# ==================== JWT 认证 ====================
# 建议生成一个随机密钥，生产环境务必修改
JWT_SECRET_KEY=your-super-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# ==================== 飞书 / Lark 集成 ====================
# 飞书自建应用 App ID / Secret（可选）
FEISHU_APP_ID=your-feishu-app-id
FEISHU_APP_SECRET=your-feishu-app-secret
FEISHU_BASE_URL=https://open.feishu.cn/open-apis
# 飞书多维表格 app_token（可选）
FEISHU_BITABLE_APP_TOKEN=your-bitable-app-token
# 默认群聊 ID / 文档目录 token（可选）
FEISHU_DEFAULT_CHAT_ID=oc_your_chat_id
FEISHU_DEFAULT_FOLDER_TOKEN=your_folder_token

# ==================== 其他配置 ====================
MEM_LIMIT=8073741824
TIMEZONE=Asia/Shanghai
